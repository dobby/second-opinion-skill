{
  "manifest_version": 3,
  "name": "Second Opinion",
  "version": "1.0.0",
  "description": "Relay agent questions to Grok AI via the active tab",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://grok.com/*", "ws://localhost/*"],
  "background": {"service_worker": "background.js"},
  "content_scripts": [
    {
      "matches": ["https://grok.com/*"],
      "js": ["content-bridge.js"],
      "world": "ISOLATED"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["content-page.js"],
      "world": "MAIN"
    }
  ],
  "action": {"default_popup": "popup.html", "default_title": "Second Opinion"}
}
